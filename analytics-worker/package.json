{
  "name": "echoops-portfolio-analytics-worker",
  "private": true,
  "type": "module",
  "scripts": {
    "check": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:dry": "wrangler deploy --dry-run --outdir .wrangler-dist",
    "db:init": "wrangler d1 execute echoops-portfolio-analytics --remote --file schema.sql",
    "db:migrate": "wrangler d1 execute echoops-portfolio-analytics --remote --file migrations/0002_snake_achievement.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "typescript": "^7.0.2",
    "wrangler": "^4.110.0"
  }
}
